---
import MainPageLayout from '@layouts/MainPageLayout.astro'
import { siteConfig, friendLinkConfig } from '@/config'
import Cover from '@components/Cover.astro';
import Markdown from '@components/misc/Markdown.astro';

import { getSpec } from '@utils/content-utils'

import i18nit from '@i18n/translation';
import { render } from 'astro:content'
import { i18n } from "astro:config/client";

export async function getStaticPaths() {
	return i18n?.locales.map(locale => ({ params: { locale: locale == i18n?.defaultLocale ? undefined : (locale as string) } }));
}

const currentLang = Astro.currentLocale || i18n!.defaultLocale;
const t = i18nit(currentLang);

const friendsPost = await getSpec(currentLang, 'friends');
if (!friendsPost) {
    throw new Error('No friends post found');
}
const { Content } = await render(friendsPost);

const pageTitle = t("header.friends") + " - " + siteConfig.title;
---

<MainPageLayout title={pageTitle} lang={currentLang}>
    <div class="mx-auto w-full max-w-[var(--page-width)]">
        <Cover title={t("cover.title.friends")} subTitle={t("cover.subTitle.friends")} />
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-[var(--text-color)] mb-12">
            {
                friendLinkConfig.map((friend) => (
                    <a 
                        href={friend.url} 
                        target="_blank" 
                        rel="noopener noreferrer"
                        class="group flex items-center justify-between p-4 border border-[var(--button-border-color)] rounded-lg shadow-sm active:bg-[var(--button-hover-color)] hover:bg-[var(--button-hover-color)] transition-all duration-300"
                    >
                        <div class="flex items-center min-w-0">
                            <img 
                                src={friend.avatar} 
                                alt={friend.name} 
                                class="w-16 h-16 rounded-full object-cover mr-4 flex-shrink-0"
                                onerror="this.setAttribute('src', 'https://www.gravatar.com/avatar/?d=mp')"
                            />
                            <div class="min-w-0">
                                <h2 class="font-bold text-lg truncate transition-colors duration-300 group-hover:text-[var(--link-color)]">{friend.name}</h2>
                                <p class="text-[var(--text-color-70)] text-sm truncate">{friend.description}</p>
                            </div>
                        </div>
                        
                        <svg 
                            xmlns="http://www.w3.org/2000/svg" 
                            fill="none" 
                            viewBox="0 0 24 24" 
                            stroke-width="2" 
                            stroke="currentColor" 
                            class="w-5 h-5 text-[var(--link-color)] opacity-0 transform translate-x-[-10px] group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 ml-2 flex-shrink-0"
                        >
                            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                        </svg>
                    </a>
                ))
            }
        </div>
        <Markdown class="mb-6 markdown-content onload-animation">
            <Content />
        </Markdown>
    </div>
</MainPageLayout>
