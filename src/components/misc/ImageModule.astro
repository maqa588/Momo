---
// ImageModule 对应的 CSS 需要设置为 is::global 才能被正确应用

import { siteConfig } from '@/config';
import { Image } from "astro:assets";
import path from "path"
import { getLqipGradient } from "@utils/getLqipColors";

interface Props {
    src: string;
    alt?: string;
    id?: string;
    class?: string;
    width?: number;
    height?: number;
}

const { src, alt, id, width, height } = Astro.props;
const className = Astro.props.class;

const isLocal = !(
    src.startsWith("/") ||
    src.startsWith("http")
);

let imageLoad;
let lqipGradient = "";
const enableLQIP = siteConfig.theme.LQIP;

if (isLocal) {
  const images = import.meta.glob<ImageMetadata>(
    "../../**/*.{avif,gif,jpeg,jpg,png,svg,webp}",
    { import: "default" }
  );
  let imagePath = path.normalize(path.join("../../", "/", src)).replace(/\\/g, "/");
  const imageGetter = images[imagePath];

  if (!imageGetter) {
    console.error(`\n[ERROR] Image file not found: ${imagePath}`);
  } else {
    imageLoad = await imageGetter();
    if(enableLQIP) {
      const imageFsPath = (imageLoad as ImageMetadata & { fsPath: string }).fsPath;
      lqipGradient = await getLqipGradient(imageFsPath);
    }
  }
}
---
<div 
  class:list={["image-wrapper", className]} 
  style={{ "--lqip": lqipGradient }}
  data-lqip-enabled={enableLQIP}
>
    <div class="lqip-bg"></div>
    {
        isLocal && imageLoad && (
        <Image 
            src={imageLoad} 
            alt={alt || ""} 
            id={id} 
            width={width} 
            height={height}
            class=""
            onload="this.parentElement.dataset.loaded = 'true'" 
        />
        )
    }
  
    {
        !isLocal && (
        <img 
            src={src} 
            alt={alt || ""} 
            id={id} 
            width={width} 
            height={height} 
            loading="lazy"
            class=""
        />
        )
    }
</div>

<style>
.image-wrapper {
    position: relative;
    overflow: hidden;
    background-color: transparent;
    display: block;
}

.lqip-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--lqip);
    filter: blur(40px); 
    transform: scale(1.2); /* 放大一点防止边缘出现白边 */
    z-index: 0;
    transition: opacity 0.8s ease;
}

.image-wrapper img {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0;
    transition: opacity 0.6s ease-in-out;
}

/* 图片加载完成后 */
.image-wrapper[data-loaded="true"] img {
    opacity: 1;
}

.image-wrapper[data-loaded="true"][data-lqip-enabled="true"] .lqip-bg {
    opacity: 0; /* 加载完后隐藏背景层 */
}

.image-wrapper[data-lqip-enabled="false"] .lqip-bg {
    display: none; /* 禁用 LQIP 时不显示模糊背景 */
}

.image-wrapper[data-lqip-enabled="false"] img {
    opacity: 1; /* 禁用 LQIP 时直接显示图片 */
}
</style>
